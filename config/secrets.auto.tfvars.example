# =============================================================================
# SECRETS — copy this file to "secrets.auto.tfvars" and fill in real values.
#
#   cp config/secrets.auto.tfvars.example config/secrets.auto.tfvars
#
# The real "secrets.auto.tfvars" is git-ignored and MUST NEVER be committed.
# This repository is PUBLIC. Treat every value below as highly sensitive.
# Prefer supplying these via a cloud secret store (see modules/secrets/README.md)
# for production; the values below are the local/manual default.
# =============================================================================

# --- Cloudflare (build-time: used by the Terraform Cloudflare provider) -------
# Scope the API token to ONLY: Zone:DNS:Edit, Account:Cloudflare Tunnel:Edit,
# Account:Access:Edit. Never use a Global API Key.
cloudflare_account_id = "your-cloudflare-account-id"
cloudflare_api_token  = "your-scoped-cloudflare-api-token"

# --- Foundry VTT software download (used ONCE by the container) ---------------
# Option A (recommended): your Foundry account credentials. The felddy container
# uses these to authenticate the license-gated download, then discards them.
foundry_username = ""
foundry_password = ""

# Option B: a Foundry "Timed URL" (expires ~5 minutes). If set, this is used
# instead of username/password. Leave blank to use Option A.
foundry_release_url = ""

# --- Foundry VTT runtime secrets ---------------------------------------------
# License key, format: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX
foundry_license_key = ""

# Administrator (setup) password that gates the Foundry /setup screen.
# Use a long, unique, randomly generated value.
foundry_admin_key = ""
